# Outlook Email Plus（邮箱池中台）
# 小站同机推荐内网：http://host.docker.internal:5001
# 公网：https://outlook.api4kimi8.org
OEP_BASE_URL=http://host.docker.internal:5001
OEP_API_KEY=your-oep-external-api-key
# 池筛选：outlook / imap / custom（禁止 cloudflare_temp_mail）
OEP_PROVIDER=outlook
OEP_PROJECT_KEY=gptsignup
OEP_CALLER_ID=gptsignup

# 兼容旧变量名（可选；优先读 OEP_*）
# MAIL_BASE_URL=
# MAIL_API_KEY=

# 可选：访问 OpenAI 的代理
PROXY=
# 兼容：也可使用系统 HTTP_PROXY / HTTPS_PROXY

# 批处理默认值（可被 CLI 覆盖）
# GPT_WORKERS=3
# GPT_TOTAL=1
