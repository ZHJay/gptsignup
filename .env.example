# Outlook Email Plus（邮箱池中台）
# 小站同机 Docker 推荐：http://outlook-email-plus:5000
# 本机：http://127.0.0.1:5001  公网：https://outlook.api4kimi8.org
OEP_BASE_URL=http://outlook-email-plus:5000
OEP_API_KEY=your-oep-external-api-key
OEP_PROVIDER=outlook
OEP_PROJECT_KEY=gptsignup
OEP_CALLER_ID=gptsignup
# 仅从此分组领取（默认「默认分组」）
OEP_CLAIM_GROUP=默认分组
# OEP_CLAIM_GROUP_RETRIES=30
# 管理端密码：用于校验领取账号所属分组（claim-random 本身不筛组）
# OEP_ADMIN_PASSWORD=

# Sub2API 管理端（注册成功后导入账号）
SUB2API_BASE_URL=https://api4kimi8.org
SUB2API_ADMIN_EMAIL=admin@example.com
SUB2API_ADMIN_PASSWORD=your-admin-password
# 兼容：ADMIN_EMAIL / ADMIN_PASSWORD

# Tiger SMS v2（OAuth 手机验证）
# 文档：https://tiger-sms.com/cn/api#m-getNumberV2
TIGER_SMS_API_KEY=your-tiger-sms-api-key
TIGER_SMS_SERVICE=dr
TIGER_SMS_COUNTRY=1001
# TIGER_SMS_MAX_PRICE=
# TIGER_SMS_POLL_SECONDS=120
# TIGER_SMS_NUMBER_RETRIES=3

# 可选：访问 OpenAI 的代理（Playwright）
PROXY=

# 浏览器（CF 对 headless 很严；本机默认有头 Chrome）
# BROWSER_HEADLESS=0
# BROWSER_CHANNEL=chrome
# BROWSER_TIMEOUT_MS=120000
# VDS 无值守：BROWSER_HOLD=0（默认 --yes 也不 hold）；本机调试可 BROWSER_HOLD=1
# BROWSER_HOLD=0

# GPT_WORKERS=1
# GPT_TOTAL=1
